# Docker Hub account
DOCKERHUB_USER=your_dockerhub_username

# Image prefix created by push script (example: docker-manager)
REPO_PREFIX=docker-manager

# Image tag to deploy
TAG=latest

# Optional port mapping on host
BACKEND_PORT=8080
FRONTEND_PORT=80

# Docker socket path (Linux default)
DOCKER_SOCK=/var/run/docker.sock
